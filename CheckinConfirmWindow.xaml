<Window x:Class="ExcelFinder.CheckinConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="체크인 확인"
        Width="980"
        Height="680"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Submit Description" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="DescriptionTextBox"
                 Grid.Row="1"
                 IsReadOnly="False"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="70"
                 Margin="0,0,0,10"/>

        <GroupBox Grid.Row="2" Header="변경점" Margin="0,0,0,10">
            <DataGrid x:Name="DiffDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Excel 행" Binding="{Binding ExcelRow}" Width="90"/>
                    <DataGridTextColumn Header="컬럼" Binding="{Binding ColumnName}" Width="220"/>
                    <DataGridTextColumn Header="이전 값" Binding="{Binding BeforeValue}" Width="*"/>
                    <DataGridTextColumn Header="현재 값" Binding="{Binding AfterValue}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <DockPanel Grid.Row="3">
            <TextBlock x:Name="SummaryTextBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#444"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인" Width="110" Height="32" Margin="0,0,8,0" Click="ConfirmButton_Click"/>
                <Button Content="취소" Width="110" Height="32" Click="CancelButton_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
