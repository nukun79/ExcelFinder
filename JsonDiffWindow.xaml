<Window x:Class="ExcelFinder.JsonDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Json Diff"
        Height="700"
        Width="1100"
        MinHeight="540"
        MinWidth="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source"/>
            <TextBox x:Name="SourcePathTextBox" Grid.Column="1" Margin="0,0,8,0" Height="28" VerticalContentAlignment="Center" TextChanged="PathTextBox_TextChanged"/>
            <Button Grid.Column="2" Height="28" Content="찾기..." Click="BrowseSourceButton_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Target"/>
            <TextBox x:Name="TargetPathTextBox" Grid.Column="1" Margin="0,0,8,0" Height="28" VerticalContentAlignment="Center" TextChanged="PathTextBox_TextChanged"/>
            <Button Grid.Column="2" Height="28" Content="찾기..." Click="BrowseTargetButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="2" Margin="0,0,0,8" Foreground="#666" Text="폴더 비교는 같은 상대 경로의 JSON 파일끼리 비교합니다."/>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Path"/>
            <TextBox x:Name="SourceDirPathTextBox" Grid.Column="1" Margin="0,0,8,0" Height="28" VerticalContentAlignment="Center" TextChanged="PathTextBox_TextChanged"/>
            <Button Grid.Column="2" Height="28" Content="찾기..." Click="BrowseSourceDirButton_Click"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Target Path"/>
            <TextBox x:Name="TargetDirPathTextBox" Grid.Column="1" Margin="0,0,8,0" Height="28" VerticalContentAlignment="Center" TextChanged="PathTextBox_TextChanged"/>
            <Button Grid.Column="2" Height="28" Content="찾기..." Click="BrowseTargetDirButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Width="90" Height="28" Content="파일 Diff" Click="DiffButton_Click"/>
            <Button Width="90" Height="28" Margin="8,0,0,0" Content="폴더 비교" Click="DiffFolderButton_Click"/>
            <Button Width="90" Height="28" Margin="8,0,0,0" Content="닫기" Click="CloseButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="FindTextBox"
                     Width="340"
                     Height="28"
                     VerticalContentAlignment="Center"
                     KeyDown="FindTextBox_KeyDown"/>
            <Button Width="90"
                    Height="28"
                    Margin="8,0,0,0"
                    Content="찾기"
                    Click="FindButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="DiffDataGrid"
                  Grid.Row="7"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  PreviewMouseRightButtonDown="DiffDataGrid_PreviewMouseRightButtonDown"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="값복사" Click="CopyCellValueMenuItem_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="파일" Binding="{Binding JsonFile}" Width="220"/>
                <DataGridTextColumn Header="구분" Binding="{Binding DiffType}" Width="90"/>
                <DataGridTextColumn Header="키" Binding="{Binding Key}" Width="170"/>
                <DataGridTextColumn Header="필드" Binding="{Binding FieldName}" Width="170"/>
                <DataGridTextColumn Header="Source" Binding="{Binding SourceValue}" Width="*"/>
                <DataGridTextColumn Header="Target" Binding="{Binding TargetValue}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="8" Foreground="#444"/>
    </Grid>
</Window>
