<Window x:Class="ExcelFinder.JsonExtractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JsonExporter"
        Height="640"
        Width="860"
        MinHeight="500"
        MinWidth="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Excel Path"/>
            <TextBox x:Name="ExcelPathTextBox"
                     Grid.Column="1"
                     Margin="0,0,8,0"
                     Height="28"
                     VerticalContentAlignment="Center"
                     TextChanged="ExcelPathTextBox_TextChanged"/>
            <Button Grid.Column="2"
                    Height="28"
                    Content="찾기..."
                    Click="BrowseExcelPathButton_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Json Path"/>
            <TextBox x:Name="JsonPathTextBox"
                     Grid.Column="1"
                     Margin="0,0,8,0"
                     Height="28"
                     VerticalContentAlignment="Center"
                     TextChanged="JsonPathTextBox_TextChanged"/>
            <Button Grid.Column="2"
                    Height="28"
                    Content="찾기..."
                    Click="BrowseJsonPathButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ToggleAllButton"
                    Width="90"
                    Height="28"
                    Content="All"
                    Click="ToggleAllButton_Click"/>
            <Button x:Name="ExtractButton"
                    Width="90"
                    Height="28"
                    Margin="8,0,0,0"
                    Content="추출"
                    Click="ExtractButton_Click"/>
            <Button Width="90"
                    Height="28"
                    Margin="8,0,0,0"
                    Content="닫기"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="ItemsDataGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="선택" Binding="{Binding IsChecked, Mode=TwoWay}" Width="70"/>
                <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="170" IsReadOnly="True"/>
                <DataGridTextColumn Header="그룹" Binding="{Binding GroupSummary}" Width="290" IsReadOnly="True"/>
                <DataGridTextColumn Header="대상 파일 수" Binding="{Binding FileCount}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="예상 JSON 수" Binding="{Binding OutputJsonCount}" Width="110" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel x:Name="ProgressPanel" Grid.Row="4" Visibility="Collapsed" Margin="0,8,0,4">
            <ProgressBar x:Name="ExtractProgressBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="ProgressTextBlock" Margin="0,4,0,0" Foreground="#555"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="5" Foreground="#444"/>
    </Grid>
</Window>
