<Window x:Class="ExcelFinder.PerforceConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Perforce 정보 설정"
        Height="560"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Client:" Margin="0,0,8,10"/>
        <TextBox x:Name="ClientTextBox" Grid.Row="0" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Host:" Margin="0,0,8,10"/>
        <TextBox x:Name="HostTextBox" Grid.Row="1" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Root:" Margin="0,0,8,10"/>
        <TextBox x:Name="RootTextBox" Grid.Row="2" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Stream:" Margin="0,0,8,10"/>
        <TextBox x:Name="StreamTextBox" Grid.Row="3" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Foreground="#555" Margin="0,0,0,8"
                   Text="적용 버튼을 누르면 p4 client spec에 값이 반영되고 P4CLIENT가 설정됩니다."/>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,8"/>

        <GroupBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Header="p4 info" Margin="0,0,0,8">
            <TextBox x:Name="P4InfoTextBox"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"/>
        </GroupBox>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="적용" Width="110" Height="32" Margin="0,0,8,0" Click="ApplyButton_Click"/>
            <Button Content="닫기" Width="110" Height="32" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
